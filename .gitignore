# Virtual environments
.venv/
venv/
ENV/
env/

# Node modules & frontend builds
node_modules/
dist/
dist-ssr/
*.local

# Python cache and temporary files
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
htmlcov/
.ipynb_checkpoints/

# IDE / OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Environments
.env
.env.production
.env.local
.env.development
.env.staging

# Datasets and ML Models (ignores files but preserves structure via .gitkeep)
data/raw/*
!data/raw/.gitkeep

data/processed/*
!data/processed/.gitkeep

# Ignore local ML model artifacts by default
ml/models/*

# Keep only the production model needed for deployment
!ml/models/best_satisfaction_model.joblib
!ml/models/.gitkeep

# Ignore local caching of intermediate embeddings or features
ml/cache/
*.npy
*.npz
